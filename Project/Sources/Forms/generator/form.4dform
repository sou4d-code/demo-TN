			},
			"btnConvert": {
				"type": "button",
				"stroke": "#FFFFFF", "borderStyle": "none", "fontSize": 13, "fontWeight": "bold",
				"style": "toolbar",
				"left": 14, "top": 382, "width": 244, "height": 38,
				"text": "Convert →",
				"method": "ObjectMethods/btnConvert.4dm",
				"events": ["onClick"]
			},
			"spinnerConvert": {
				"type": "spinner",
				"left": 224, "top": 389, "width": 24, "height": 24,
