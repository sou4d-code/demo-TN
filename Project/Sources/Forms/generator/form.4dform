{
	"$4d": { "version": "1", "kind": "form" },
	"windowSizingX": "fixed",
	"windowSizingY": "fixed",
	"windowMinWidth": 960,
	"windowMinHeight": 620,
	"windowMaxWidth": 960,
	"windowMaxHeight": 620,
	"rightMargin": 20,
	"bottomMargin": 20,
	"events": ["onLoad", "onClick"],
	"windowTitle": "HTML → 4D Form Converter",
	"destination": "detailScreen",
	"formClass": "formGenerator",
	"pages": [
		{ "objects": {} },
		{ "objects": {

			"rectTitleBar": {
				"type": "rectangle",
				"fill": "#0F172A",
				"stroke": "transparent",
				"borderStyle": "none",
				"left": 0, "top": 0, "width": 960, "height": 44
			},
			"tl1": {
				"type": "rectangle",
				"fill": "#FF5F57", "stroke": "transparent", "borderStyle": "none", "borderRadius": 6,
				"left": 16, "top": 16, "width": 12, "height": 12
			},
			"tl2": {
				"type": "rectangle",
				"fill": "#FEBC2E", "stroke": "transparent", "borderStyle": "none", "borderRadius": 6,
				"left": 35, "top": 16, "width": 12, "height": 12
			},
			"tl3": {
				"type": "rectangle",
				"fill": "#28C840", "stroke": "transparent", "borderStyle": "none", "borderRadius": 6,
