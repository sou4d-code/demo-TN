				"left": 14, "top": 266, "width": 244, "height": 28,
				"dataSource": "Form.formName",
				"placeholder": "myForm"
			},
			"hDivider2": {
				"type": "rectangle",
				"fill": "#E2E8F0", "stroke": "transparent", "borderStyle": "none",
