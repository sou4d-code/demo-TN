				"left": 196, "top": 172, "width": 62, "height": 28,
				"text": "Browse",
				"method": "ObjectMethods/btnBrowse.4dm",
				"events": ["onClick"]
			},
			"txtFileHint": {
				"type": "text",
				"fill": "transparent", "stroke": "#94A3B8", "borderStyle": "none", "fontSize": 10,
