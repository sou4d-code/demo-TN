{
	"$4d": {
		"version": "1",
		"kind": "form"
	},
	"windowSizingX": "fixed",
	"windowSizingY": "fixed",
	"windowMinWidth": 960,
	"windowMinHeight": 620,
	"windowMaxWidth": 960,
	"windowMaxHeight": 620,
	"rightMargin": 20,
	"bottomMargin": 20,
	"events": ["onLoad", "onClick"],
	"windowTitle": "HTML → 4D Form Converter",
	"destination": "detailScreen",
	"formClass": "formGenerator",
	"pages": [
		{
			"objects": {}
		},
		{
			"objects": {

				"rectTitleBar": {
					"type": "rectangle",
					"class": "titleBar",
					"left": 0,
					"top": 0,
					"width": 960,
					"height": 48
				},
				"tl1": {
					"type": "rectangle",
					"left": 16,
					"top": 18,
					"width": 12,
					"height": 12
				},
				"tl2": {
					"type": "rectangle",
					"left": 35,
					"top": 18,
					"width": 12,
					"height": 12
				},
				"tl3": {
					"type": "rectangle",
					"left": 54,
					"top": 18,
					"width": 12,
					"height": 12
				},
				"rectAppIcon": {
					"type": "rectangle",
					"class": "appIcon",
					"left": 367,
					"top": 15,
					"width": 18,
					"height": 18
				},
				"txtAppTitle": {
					"type": "text",
					"class": "titleText",
					"left": 392,
					"top": 14,
					"width": 220,
					"height": 22,
					"text": "HTML → 4D Form Converter"
				},
				"rectBadge": {
					"type": "rectangle",
					"class": "badgeBg",
					"left": 824,
					"top": 13,
					"width": 120,
					"height": 22
				},
				"txtBadge": {
					"type": "text",
					"class": "badgeText",
					"left": 828,
					"top": 16,
					"width": 112,
					"height": 16,
					"text": "4D AIKit · gpt-4o",
					"textAlign": "center"
				},

				"rectSidebar": {
					"type": "rectangle",
					"class": "sidebarBg",
					"left": 0,
					"top": 48,
					"width": 264,
					"height": 548
				},

				"txtSection1": {
					"type": "text",
					"class": "sectionLabel",
					"left": 8,
					"top": 63,
					"width": 248,
					"height": 14,
					"text": "SOURCE FILE"
				},
				"inputHtmlPath": {
					"type": "input",
					"class": "monoInput",
					"left": 8,
					"top": 82,
					"width": 182,
					"height": 28,
					"dataSource": "Form.htmlPath",
					"enterable": false,
					"placeholder": "No file selected…"
				},
				"btnBrowse": {
					"type": "button",
					"class": "browseBtn",
					"style": "bevel",
					"left": 196,
					"top": 82,
					"width": 60,
					"height": 28,
					"text": "Browse",
					"method": "ObjectMethods/btnBrowse.4dm",
					"events": ["onClick"]
				},
				"txtFileHint": {
					"type": "text",
					"class": "fileHint",
					"left": 8,
					"top": 116,
					"width": 248,
					"height": 14,
					"dataSource": "Form.htmlHint"
				},
				"hDivider1": {
					"type": "rectangle",
					"class": "hDivider",
					"left": 0,
					"top": 138,
					"width": 264,
					"height": 1
				},

				"txtSection2": {
					"type": "text",
					"class": "sectionLabel",
					"left": 8,
					"top": 151,
					"width": 248,
					"height": 14,
					"text": "OUTPUT"
				},
				"txtLabelFormName": {
					"type": "text",
					"class": "fieldLabel",
					"left": 8,
					"top": 173,
					"width": 248,
					"height": 14,
					"text": "Form Name"
				},
				"inputFormName": {
					"type": "input",
					"class": "stdInput",
					"left": 8,
					"top": 191,
					"width": 248,
					"height": 28,
					"dataSource": "Form.formName",
					"placeholder": "myForm"
				},
				"hDivider2": {
					"type": "rectangle",
					"class": "hDivider",
					"left": 0,
					"top": 227,
					"width": 264,
					"height": 1
				},

				"txtSection3": {
					"type": "text",
					"class": "sectionLabel",
					"left": 8,
					"top": 240,
					"width": 248,
					"height": 14,
					"text": "OPENAI"
				},
				"txtLabelApiKey": {
					"type": "text",
					"class": "fieldLabel",
					"left": 8,
					"top": 262,
					"width": 248,
					"height": 14,
					"text": "API Key"
				},
				"inputApiKey": {
					"type": "input",
					"class": "monoInput",
					"left": 8,
					"top": 280,
					"width": 248,
					"height": 28,
					"dataSource": "Form.apiKey",
					"placeholder": "sk-proj-…"
				},
				"rectConvertBg": {
					"type": "rectangle",
					"class": "convertBg",
					"left": 8,
					"top": 318,
					"width": 248,
					"height": 36
				},
				"btnConvert": {
					"type": "button",
					"class": "convertBtn",
					"left": 8,
					"top": 318,
					"width": 248,
					"height": 36,
					"text": "Convert →",
					"style": "toolbar",
					"method": "ObjectMethods/btnConvert.4dm",
					"events": ["onClick"]
				},
				"spinnerConvert": {
					"type": "spinner",
					"left": 218,
					"top": 323,
					"width": 26,
					"height": 26,
					"dataSource": "Form.actions.converting.running",
					"visibility": "hidden"
				},
				"hDivider3": {
					"type": "rectangle",
					"class": "hDivider",
					"left": 0,
					"top": 366,
					"width": 264,
					"height": 1
				},

				"txtSection4": {
					"type": "text",
					"class": "sectionLabel",
					"left": 8,
					"top": 379,
					"width": 248,
					"height": 14,
					"text": "LOG"
				},
				"areaLog": {
					"type": "input",
					"class": "logOutput",
					"left": 8,
					"top": 399,
					"width": 248,
					"height": 189,
					"dataSource": "Form.logText",
					"enterable": false,
					"multiline": "yes",
					"scrollbarVertical": "visible"
				},

				"rectVDivider": {
					"type": "rectangle",
					"class": "vDivider",
					"left": 264,
					"top": 48,
					"width": 1,
					"height": 548
				},

				"rectPreviewHeader": {
					"type": "rectangle",
					"class": "previewHeaderBg",
					"left": 265,
					"top": 48,
					"width": 695,
					"height": 42
				},
				"tabMain": {
					"type": "tab",
					"left": 277,
					"top": 57,
					"width": 200,
					"height": 26,
					"dataSource": "Form.activeTab",
					"choiceList": ["Live Preview", "Output JSON"],
					"method": "ObjectMethods/tabMain.4dm",
					"events": ["onClick"]
				},
				"txtPreviewUrl": {
					"type": "text",
					"class": "urlBadge",
					"left": 700,
					"top": 62,
					"width": 250,
					"height": 18,
					"dataSource": "Form.previewUrl",
					"textAlign": "right"
				},
				"rectPreviewDivider": {
					"type": "rectangle",
					"class": "previewHDivider",
					"left": 265,
					"top": 90,
					"width": 695,
					"height": 1
				},

				"webPreview": {
					"type": "webArea",
					"left": 265,
					"top": 91,
					"width": 695,
					"height": 505,
					"dataSource": "Form.previewUrl"
				},
				"areaJsonOutput": {
					"type": "input",
					"class": "jsonOutput",
					"left": 265,
					"top": 91,
					"width": 695,
					"height": 505,
					"dataSource": "Form.generatedJson",
					"enterable": false,
					"multiline": "yes",
					"scrollbarVertical": "visible",
					"visibility": "hidden"
				},

				"rectStatusBar": {
					"type": "rectangle",
					"class": "darkBar",
					"left": 0,
					"top": 596,
					"width": 960,
					"height": 24
				},
				"rectStatusDot": {
					"type": "rectangle",
					"class": "statusDot",
					"left": 14,
					"top": 607,
					"width": 6,
					"height": 6
				},
				"txtStatusMain": {
					"type": "text",
					"class": "statusGreen",
					"left": 26,
					"top": 603,
					"width": 260,
					"height": 16,
					"dataSource": "Form.statusText"
				},
				"rectStatusSep1": {
					"type": "rectangle",
					"class": "statusSep",
					"left": 290,
					"top": 604,
					"width": 1,
					"height": 12
				},
				"txtStatusTokens": {
					"type": "text",
					"class": "statusDim",
					"left": 298,
					"top": 603,
					"width": 120,
					"height": 16,
					"dataSource": "Form.tokenText"
				},
				"rectStatusSep2": {
					"type": "rectangle",
					"class": "statusSep",
					"left": 422,
					"top": 604,
					"width": 1,
					"height": 12
				},
				"txtStatusVersion": {
					"type": "text",
					"class": "statusDim",
					"left": 430,
					"top": 603,
					"width": 160,
					"height": 16,
					"dataSource": "Form.versionText"
				}

			}
		}
	]
}
