{
	"$4d": {
		"version": "1",
		"kind": "form"
	},
	"windowSizingX": "variable",
	"windowSizingY": "variable",
	"windowMinWidth": 0,
	"windowMinHeight": 0,
	"windowMaxWidth": 32767,
	"windowMaxHeight": 32767,
	"rightMargin": 20,
	"bottomMargin": 20,
	"events": ["onLoad", "onClick"],
	"windowTitle": "HTML → 4D Form Converter",
	"destination": "detailScreen",
	"formClass": "formGenerator",
	"pages": [
		{
			"objects": {}
		},
		{
			"objects": {
				"rectHeader": {
					"type": "rectangle",
					"class": "header",
					"left": 0,
					"top": 0,
					"width": 820,
					"height": 56
				},
				"txtTitle": {
					"type": "text",
					"class": "headerTitle",
					"left": 20,
					"top": 14,
					"width": 620,
					"height": 28,
					"text": "HTML → 4D Form Converter"
				},
				"txtSubtitle": {
					"type": "text",
					"class": "headerSubtitle",
					"left": 650,
					"top": 20,
					"width": 150,
					"height": 18,
					"text": "Powered by 4D AIKit"
				},
				"lblHtmlFile": {
					"type": "text",
					"class": "formLabel",
					"left": 20,
					"top": 76,
					"width": 80,
					"height": 20,
					"text": "HTML File:"
				},
				"inputHtmlPath": {
					"type": "input",
					"class": "inputReadOnly",
					"left": 108,
					"top": 72,
					"width": 586,
					"height": 26,
					"dataSource": "Form.htmlPath",
					"enterable": false
				},
				"btnBrowse": {
					"type": "button",
					"class": "secondaryBtn",
					"left": 704,
					"top": 72,
					"width": 96,
					"height": 26,
					"text": "Browse…",
					"method": "ObjectMethods/btnBrowse.4dm",
					"events": ["onClick"]
				},
				"rectDivider": {
					"type": "rectangle",
					"class": "divider",
					"left": 20,
					"top": 112,
					"width": 780,
					"height": 1
				},
				"lblPreview": {
					"type": "text",
					"class": "formLabel",
					"left": 20,
					"top": 120,
					"width": 100,
					"height": 18,
					"text": "Live Preview"
				},
				"webPreview": {
					"type": "webArea",
					"left": 20,
					"top": 142,
					"width": 460,
					"height": 340,
					"dataSource": "Form.previewUrl"
				},
				"rectRightPanel": {
					"type": "rectangle",
					"class": "panelCard",
					"left": 494,
					"top": 114,
					"width": 308,
					"height": 370
				},
				"lblFormName": {
					"type": "text",
					"class": "formLabel",
					"left": 510,
					"top": 126,
					"width": 276,
					"height": 18,
					"text": "Output Form Name"
				},
				"inputFormName": {
					"type": "input",
					"class": "inputField",
					"left": 510,
					"top": 148,
					"width": 276,
					"height": 26,
					"dataSource": "Form.formName"
				},
				"lblApiKey": {
					"type": "text",
					"class": "formLabel",
					"left": 510,
					"top": 190,
					"width": 276,
					"height": 18,
					"text": "OpenAI API Key"
				},
				"inputApiKey": {
					"type": "input",
					"class": "inputField",
					"left": 510,
					"top": 212,
					"width": 276,
					"height": 26,
					"dataSource": "Form.apiKey"
				},
				"btnConvert": {
					"type": "button",
					"class": "primaryBtn",
					"left": 510,
					"top": 256,
					"width": 276,
					"height": 40,
					"text": "Convert →",
					"method": "ObjectMethods/btnConvert.4dm",
					"events": ["onClick"]
				},
				"spinnerConvert": {
					"type": "spinner",
					"left": 728,
					"top": 262,
					"width": 28,
					"height": 28,
					"dataSource": "Form.actions.converting.running",
					"visibility": "hidden"
				},
				"lblLog": {
					"type": "text",
					"class": "formLabel",
					"left": 510,
					"top": 314,
					"width": 276,
					"height": 18,
					"text": "Log"
				},
				"areaLog": {
					"type": "input",
					"class": "logArea",
					"left": 510,
					"top": 336,
					"width": 276,
					"height": 140,
					"dataSource": "Form.logText",
					"enterable": false,
					"multiline": "yes",
					"scrollbarVertical": "visible"
				},
				"rectStatusBar": {
					"type": "rectangle",
					"class": "statusBar",
					"left": 0,
					"top": 488,
					"width": 820,
					"height": 30
				},
				"txtStatus": {
					"type": "text",
					"class": "statusText",
					"left": 20,
					"top": 496,
					"width": 780,
					"height": 16,
					"dataSource": "Form.statusText"
				}
			}
		}
	]
}
