			},
			"inputHtmlPath": {
				"type": "input",
				"fill": "#F8FAFC", "stroke": "#E2E8F0", "borderStyle": "solid", "borderRadius": 6,
				"fontSize": 11, "fontFamily": "Menlo",
				"left": 14, "top": 172, "width": 176, "height": 28,
				"dataSource": "Form.htmlPath",
				"enterable": false,
				"placeholder": "No file selected…"
			},
			"btnBrowse": {
				"type": "button",
				"stroke": "#374151", "borderStyle": "solid", "borderRadius": 6, "fontSize": 12,
