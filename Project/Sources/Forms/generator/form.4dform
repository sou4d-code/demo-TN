				"left": 14, "top": 113, "width": 82, "height": 16,
				"text": "Project Mode", "textAlign": "center"
			},
			"rectPill2": {
				"type": "rectangle",
				"fill": "#1D4ED8", "stroke": "#3B82F6", "borderStyle": "solid", "borderRadius": 9,
