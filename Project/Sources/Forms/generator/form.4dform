				"left": 14, "top": 344, "width": 244, "height": 28,
				"dataSource": "Form.apiKey",
				"placeholder": "sk-proj-…"
			},
			"rectConvertBg": {
				"type": "rectangle",
				"fill": "#2563EB", "stroke": "transparent", "borderStyle": "none", "borderRadius": 8,
